NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
NEXT_PUBLIC_AGENTS_HAUS_PROGRAM_ID=BWFsJXqoXKg53yu3VxYV9YgmvTc9BZxto4CGJqYn8aWM

# Soul NFT image uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-read-write-token

# Fly.io (agent runtime deployment)
FLY_API_TOKEN=your-fly-deploy-token
FLY_APP_NAME=agents-haus-runtime
FLY_RUNTIME_IMAGE=registry.fly.io/agents-haus-runtime:latest

# Optional IronClaw profile runtime image.
# If unset, selecting IronClaw falls back to FLY_RUNTIME_IMAGE.
FLY_IRONCLAW_RUNTIME_IMAGE=registry.fly.io/agents-haus-runtime:ironclaw-latest

# IronClaw self-hosted runtime bootstrap (required when runtimeProvider=ironclaw).
# Use dedicated runtime DB credentials (recommended).
FLY_IRONCLAW_DATABASE_BACKEND=postgres
FLY_IRONCLAW_DATABASE_URL=postgres://user:pass@host:5432/ironclaw

# Optional libSQL alternative (set backend=libsql).
# FLY_IRONCLAW_LIBSQL_PATH=/home/ironclaw/.ironclaw/ironclaw.db
# FLY_IRONCLAW_LIBSQL_URL=
# FLY_IRONCLAW_LIBSQL_AUTH_TOKEN=

# IronClaw LLM bootstrap (defaults to nearai).
FLY_IRONCLAW_LLM_BACKEND=nearai
NEAR_AI_CLOUD_API_KEY=your-near-ai-cloud-api-key
FLY_IRONCLAW_NEARAI_BASE_URL=https://cloud-api.near.ai
# Optional gateway overrides (defaults shown):
# FLY_IRONCLAW_GATEWAY_HOST=0.0.0.0
# FLY_IRONCLAW_GATEWAY_PORT=3001
# FLY_IRONCLAW_GATEWAY_AUTH_TOKEN=choose-a-strong-token
# Optional session-token auth instead of API key:
# FLY_IRONCLAW_NEARAI_SESSION_TOKEN=rt_...
